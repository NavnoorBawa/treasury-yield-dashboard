# Optional licensed on-the-run U.S. Treasury intraday gateway.
# Leave INTRADAY_GATEWAY_URL empty to keep the dashboard in its honest
# "feed not connected" state. Never expose the gateway token to Vite.
INTRADAY_GATEWAY_URL=
INTRADAY_GATEWAY_TOKEN=
INTRADAY_PROVIDER_NAME=CME BrokerTec
INTRADAY_VENUE=BrokerTec
INTRADAY_DELAY_MINUTES=0
INTRADAY_REFRESH_INTERVAL_SECONDS=15
INTRADAY_CACHE_TTL_MS=5000
